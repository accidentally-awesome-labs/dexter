{
  "name": "dexter",
  "version": "1.0.0",
  "description": "Dexter v1 autonomous software factory",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "start": "tsx src/index.ts run",
    "run:sample": "DEXTER_AUTO_APPROVE_HITL=true tsx src/index.ts run --project sample-app --idea \"Build a production-ready internal tools API\"",
    "run:resume": "tsx src/index.ts run-resume",
    "resume:check": "tsx src/index.ts resume-check",
    "ops:status": "tsx src/index.ts ops-status --latest true --output table",
    "deploy:self": "tsx src/index.ts deploy-self --control-plane coolify --app dexter",
    "deploy:drill": "tsx src/index.ts deploy-self --control-plane coolify --app dexter --rollback-drill true --require-real true",
    "deploy:drill:api": "tsx src/index.ts deploy-self --control-plane coolify --app dexter --rollback-drill true --require-real true --require-api true",
    "deploy:drill:api:local": "tsx src/dev/run-local-api-drill.ts",
    "promotion:pipeline": "tsx src/index.ts promotion-pipeline --require-api true",
    "promotion:pipeline:local": "tsx src/dev/run-promotion-pipeline-local.ts --promotion-seq 1",
    "promotion:pipeline:local:2": "npm run promotion:pipeline:local && tsx src/dev/run-promotion-pipeline-local.ts --promotion-seq 2 --target-service dexter-ops-api --app dexter-ops-api",
    "promotion:pipeline:local:3": "tsx src/dev/run-promotion-pipeline-local.ts --promotion-seq 3 --target-service dexter-worker --app dexter-worker",
    "governance:verify": "tsx src/index.ts governance-verify --minimum-promotions 2",
    "governance:verify:3": "tsx src/index.ts governance-verify --minimum-promotions 3",
    "promotion:repeatability": "tsx src/index.ts promotion-repeatability --minimum-promotions 3",
    "operator:readiness": "tsx src/index.ts operator-readiness",
    "canary:rollback:drill": "tsx src/dev/run-canary-rollback-drill.ts",
    "milestone:m1:signoff": "tsx src/index.ts milestone-signoff --milestone 1",
    "trust:gates": "tsx src/release/run-trust-gates-drill.ts",
    "dogfood:run": "tsx src/dogfood/run-scenarios.ts",
    "pilot:run": "tsx src/dogfood/run-pilot-batch.ts",
    "dogfood:metrics": "tsx src/index.ts dogfood-metrics",
    "deploy-auth:revoke": "tsx src/index.ts deploy-auth-revoke",
    "attest:verify": "tsx src/index.ts attest-verify",
    "provenance:verify": "tsx src/index.ts provenance-verify",
    "release:decision": "tsx src/release/generate-go-no-go.ts",
    "soak:cycle": "tsx src/release/run-soak-cycle.ts",
    "readiness:report": "tsx src/index.ts readiness-report",
    "supervisor:route": "tsx src/index.ts supervisor-route",
    "escalation:update": "tsx src/index.ts escalation-update",
    "escalation:list": "tsx src/index.ts escalation-list",
    "escalation:resolve": "tsx src/index.ts escalation-resolve",
    "benchmark": "tsx src/tech-radar/benchmark.ts",
    "benchmark:backend": "tsx src/providers/agents/benchmark.ts",
    "test:unit": "vitest run",
    "test": "vitest run && npm run run:sample && npm run benchmark:backend && npm run soak:cycle -- --target-streak 1 --enforce-gate false && tsx src/index.ts verify"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "@opentelemetry/api": "^1.9.1",
    "dotenv": "^17.4.2",
    "fs-extra": "^11.3.5",
    "pino": "^10.3.1",
    "uuid": "^14.0.0",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^25.9.0",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  }
}
