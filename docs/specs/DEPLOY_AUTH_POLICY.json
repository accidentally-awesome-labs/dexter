{
  "schemaVersion": "1.0",
  "allowCrossEnvironment": true,
  "allowedTransitions": [
    { "from": "dev", "to": "staging" },
    { "from": "development", "to": "staging" },
    { "from": "staging", "to": "canary" },
    { "from": "canary", "to": "prod" },
    { "from": "canary", "to": "production" }
  ],
  "controlPlaneByEnvironment": {
    "dev": ["coolify", "dokploy", "dokku"],
    "development": ["coolify", "dokploy", "dokku"],
    "staging": ["coolify", "dokploy", "dokku"],
    "canary": ["coolify"],
    "prod": ["coolify"],
    "production": ["coolify"]
  }
}
