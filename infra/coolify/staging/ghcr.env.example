# Coolify GHCR pull wiring (copy to staging host .env)
DEXTER_REGISTRY=ghcr.io/accidentally-awesome-labs
# Public packages: no registry login required on the Coolify Docker host.
# Private packages: run on the Coolify host before deploy:
#   echo "$GHCR_PAT" | docker login ghcr.io -u YOUR_GITHUB_USER --password-stdin
COOLIFY_APP_NAME=dexter
