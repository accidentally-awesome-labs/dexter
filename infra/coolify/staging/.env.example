# Staging VPS — copy to infra/coolify/staging/.env
# Used by docker compose in this directory and scripts/staging-vps-*.sh

# --- Public DNS (required for TLS profile / GitHub secrets) ---
STAGING_DOMAIN=staging.example.com
CADDY_ACME_EMAIL=ops@example.com

# --- Coolify panel (localhost on VPS; public URL via Caddy) ---
APP_PORT=8001
COOLIFY_ORIGIN=https://coolify.staging.example.com
COOLIFY_API_TOKEN=

# --- Dexter bridge ---
DEXTER_BRIDGE_PORT=9876
DEXTER_BRIDGE_TOKEN=
DEXTER_COOLIFY_API_URL=https://bridge.staging.example.com
DEXTER_COOLIFY_TOKEN=

# --- Coolify app mapping (infra/coolify/apps.json on repo; UUID from panel) ---
COOLIFY_APP_UUID=

# --- Registry ---
DEXTER_REGISTRY=ghcr.io/accidentally-awesome-labs

# --- Deploy auth (use non-default values in production) ---
DEXTER_DEPLOY_AUTH_KEY=
DEXTER_POLICY_BUNDLE_KEY=

# --- App health (Coolify FQDN for strict E2E / promotion) ---
DEXTER_DEPLOY_HEALTH_URL=https://dexter.staging.example.com/

# --- Optional: repo root .env sync (bootstrap writes ../local/.env for Coolify compose) ---
