# Dexter production integration (copy to .env and fill in real values)
# See docs/operations/PRODUCTION_INTEGRATION.md

# --- Control plane (HTTP deploy bridge) ---
# Dexter POSTs to /deploy and /rollback with Bearer auth (see coolify-api.ts).
# Use a small bridge service or hook-backed endpoint — not raw Coolify UI URLs unless they implement this contract.
DEXTER_COOLIFY_API_URL=https://deploy-bridge.example
DEXTER_COOLIFY_TOKEN=
# Optional path overrides (default /deploy, /rollback):
# DEXTER_COOLIFY_DEPLOY_PATH=/deploy
# DEXTER_COOLIFY_ROLLBACK_PATH=/rollback
# Legacy aliases:
# DEXTER_CONTROL_PLANE_ENDPOINT=
# DEXTER_CONTROL_PLANE_TOKEN=

# Dokploy / Dokku use the same HTTP contract with provider-specific env names:
# DEXTER_DOKPLOY_API_URL=
# DEXTER_DOKPLOY_TOKEN=
# DEXTER_DOKKU_API_URL=
# DEXTER_DOKKU_TOKEN=

# --- Post-deploy health ---
DEXTER_DEPLOY_HEALTH_URL=https://staging.example/health
# DEXTER_DEPLOY_HEALTH_URLS=https://staging.example/health,https://canary.example/health
# DEXTER_DEPLOY_HEALTH_TIMEOUT_MS=5000

# --- Deploy authorization (use non-default keys in production) ---
DEXTER_DEPLOY_AUTH_KEY=
DEXTER_POLICY_BUNDLE_KEY=
DEXTER_DEPLOY_APPROVER=release-manager
DEXTER_DEPLOY_ENV=production
DEXTER_DEPLOY_TENANT=default

# --- Canary SLO inputs (or pass --canary-metrics snapshot.json) ---
# DEXTER_CANARY_ERROR_RATE_5XX=0.02
# DEXTER_CANARY_P95_LATENCY_MS=1200
# DEXTER_CANARY_ERROR_BUDGET_BURN=2

# --- Alerts (Slack/Pager/generic incoming webhooks) ---
DEXTER_ALERT_WEBHOOK_URL=
DEXTER_ALERT_CHAT_WEBHOOK_URL=
DEXTER_ALERT_PAGER_WEBHOOK_URL=

# --- Attestation / approvals ---
# DEXTER_ATTESTATION_KEY=
# DEXTER_APPROVAL_SIGNING_KEY=

# --- Optional agent / research ---
# DEXTER_AGENT_BACKEND=cursor-cli
# DEXTER_RESEARCH_API_URL=
# DEXTER_RESEARCH_API_KEY=
